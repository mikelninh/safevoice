# SafeVoice Environment Variables
# Copy this file to .env and fill in the values.

# ── Database ──
# Railway provides this automatically when you add a Postgres plugin.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./safevoice.db

# ── AI / Classifier ──
# Tier 1: OpenAI GPT-4o-mini classifier (optional — falls back to regex without it)
OPENAI_API_KEY=

# ── Security ──
# Comma-separated allowed CORS origins.
# In production, set to your Railway domain e.g. https://safevoice-production.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Requests per minute per IP (default 120)
RATE_LIMIT_RPM=120

# ── Development ──
# Set to any value to disable rate limiting (used in tests)
# TESTING=1

# Set to "true" to enable SQLAlchemy query logging
# SQL_DEBUG=true
